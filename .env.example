# JumpPark — API pública (somente leitura)
# Documentação: https://docs.jumpparkapi.com.br/public/
JUMPPARK_API_BASE_URL=
JUMPPARK_API_TOKEN=
JUMPPARK_API_USER_ID=
JUMPPARK_ESTABLISHMENT_ID=
# Origem autorizada no painel JumpPark (usada em Origin/Referer). Opcional.
JUMPPARK_API_ORIGIN=

# Banco de dados (Postgres — Vercel Postgres ou Neon). Ausente = app usa armazenamento em
# memória, não persistente (ver docs/database-and-auth-setup-guide.md).
DATABASE_URL=

# Gate de acesso temporário (middleware.ts) — desativado por padrão. Só ative depois de definir
# usuário/senha fortes. Nunca versione valores reais aqui. Ver
# docs/database-and-auth-setup-guide.md, seção "Como ativar o gate temporário".
APP_ACCESS_ENABLED=
APP_ACCESS_USERNAME=
APP_ACCESS_PASSWORD=

# Integrações futuras (não utilizadas nesta fase)
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

MERCADOLIVRE_CLIENT_ID=
MERCADOLIVRE_CLIENT_SECRET=

STONE_API_KEY=
STONE_ACCOUNT_ID=

WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

CAMERAS_BRIDGE_URL=
CAMERAS_BRIDGE_TOKEN=
